classDiagram
    %% PawPal+ class design — keep this in sync with the code as it evolves.

    class Pet {
        +str name
        +str breed
        +list~str~ care_needs
    }

    class Owner {
        +str name
        +int total_available_minutes
    }

    class Task {
        +str name
        +int duration_minutes
        +Priority priority
    }

    class Scheduler {
        +Owner owner
        +list~Task~ tasks
        +add_task(task Task) void
        +sort_tasks() list~Task~
        +generate_plan() list~Task~
    }

    class Priority {
        <<enumeration>>
        LOW
        MEDIUM
        HIGH
    }

    Owner "1" --> "*" Pet : cares for
    Scheduler "1" --> "1" Owner : plans for
    Scheduler "1" --> "*" Task : orders
    Task ..> Priority : uses
